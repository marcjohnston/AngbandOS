<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AngbandOS.Avalonia.MainWindow"
        Title="AngbandOS.Avalonia"
        Background="Black"
        Width="1600" Height="900"
        KeyDown="OnKeyDown"
        TextInput="OnTextInput"
        >
  <!-- Host panel. The UniformGrid is created in code-behind to avoid XAML UniformGrid xmlns issues. -->
  <Border Name="Root" Background="Black" />
</Window>
